# Скопируйте этот файл в .env.local и заполните реальными значениями.
# .env.local не коммитится (см. .gitignore).

# ===== Telegram =====
# Получите токен в @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# ID канала или чата, куда бот будет публиковать сообщения.
# Для канала: добавьте бота админом, опубликуйте сообщение,
# откройте https://api.telegram.org/bot<TOKEN>/getUpdates и возьмите chat.id (обычно отрицательный).
TELEGRAM_CHAT_ID=3972342896

# ===== SMTP =====
# Пример для Yandex: smtp.yandex.ru, порт 465, secure=true.
# Пример для Gmail:  smtp.gmail.com,  порт 465, secure=true (нужен app password при 2FA).
# Пример для Mail.ru: smtp.mail.ru,    порт 465, secure=true.
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Отправитель в формате RFC 5322. Должен совпадать с SMTP_USER либо быть разрешённым алиасом.
EMAIL_FROM="Velvet District <bot@example.com>"

# Получатели через запятую. Можно несколько.
EMAIL_TO=manager1@example.com,manager2@example.com

# Префикс темы письма.
EMAIL_SUBJECT_PREFIX=[Velvet District]
